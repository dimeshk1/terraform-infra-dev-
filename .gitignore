# Local Terraform state
terraform.tfstate
terraform.tfstate.backup

# Terraform directories
.terraform/

# Sensitive variable files
*.tfvars
*.tfvars.json

# Allow environment tfvars (no secrets, only resource config)
!envs/**/*.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files
*.tfplan
